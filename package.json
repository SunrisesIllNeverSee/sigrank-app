    "html-to-image": "^1.11.13",
    "next": "^15.5.19",
    "posthog-js": "^1.396.2",
    "posthog-node": "^5.38.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "server-only": "^0.0.1",
    "stripe": "^22.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
