    "autoprefixer": "^10.4.0",
    "c8": "^11.0.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "5.8.2",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
