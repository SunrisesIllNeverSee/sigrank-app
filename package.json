    "test:ui:watch": "vitest",
    "e2e": "playwright test",
    "e2e:local": "E2E_BASE_URL=http://localhost:3000 playwright test",
    "e2e:report": "playwright show-report",
    "snapshot": "node scripts/snapshot-db.mjs"
  },
  "dependencies": {
