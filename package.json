  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "node --test __tests__/**/*.test.mjs",
    "test:canonical": "node --test __tests__/ingest/canonical.test.mjs",
